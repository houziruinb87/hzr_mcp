# 远端 NAS 部署配置
# 复制为 deploy.config 并填写实际值：cp deploy.config.example deploy.config
#
# REMOTE_HOST   NAS 的 SSH 地址（IP 或 ~/.ssh/config 里的 Host 别名，如 jkj）
# REMOTE_USER  NAS SSH 用户名（极空间一般为账号/手机号）
# REMOTE_PATH  NAS 上 mcp 工程目录（docker-compose.yml 所在目录）
# REMOTE_PORT  可选，SSH 端口，默认 22（若用别名且已在 ssh config 里配了 Port 可省略）

# REMOTE_HOST=192.168.1.10
# REMOTE_HOST=jkj
# REMOTE_USER=your_nas_ssh_user
# REMOTE_PATH=/path/to/docker/hzr_mcp
# REMOTE_PORT=10000

REMOTE_HOST=
REMOTE_USER=
REMOTE_PATH=
# REMOTE_PORT=10000
