# ---------- 小智 MCP 接入（mcp_pipe 长连接）-----------
# 接入文档：https://my.feishu.cn/wiki/HiPEwZ37XiitnwktX13cEM5KnSb
# 方式一：完整 URL（包含 token）
# MCP_ENDPOINT=wss://api.xiaozhi.me/mcp/?token=你的JWT

# 方式二：分开配置 base + token（推荐，便于 token 轮换）
# MCP_BASE_URL=wss://api.xiaozhi.me/mcp/
# MCP_TOKEN=你的JWT

# 方式三：仅配置 base，运行时传 token：python mcp_pipe.py hzr_mcp.py -t 你的JWT
# MCP_BASE_URL=wss://api.xiaozhi.me/mcp/

# ---------- 极空间 / adb（可选）-----------
# 极空间 office 容器内一般已 source env.sh，PATH 含 adb；如需指定：
# ADB_PATH=/workspace/tools/android-sdk/platform-tools/adb
# ANDROID_APK_STORE_PATH=/workspace/tools/android-sdk/store
# ANDROID_NAME_TO_IP='{"侯志锐":"10.5.234.21"}'
